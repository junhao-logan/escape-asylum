# ===== Godot 4 工程忽略项 =====
# 这些是 Godot 自动生成的，不要提交进仓库

# Godot 4 的缓存与导入数据目录
.godot/

# 旧版 Godot 3 的导入缓存（若用 Godot 3 才需要）
.import/

# 导出产物
export/
build/
builds/
*.exe
*.pck
*.zip

# 导出预设里可能含密钥，不要提交
export_presets.cfg

# Mono / C# 用户才会有（用 GDScript 可忽略此段）
.mono/
data_*/
mono_crash.*.json

# IDE
.vs/
.vscode/
.idea/
*.swp

# 操作系统
.DS_Store
Thumbs.db
desktop.ini

# ===== 项目专用 =====
# 个人密钥 / 不要泄露的东西
*.keystore
secrets.txt
.env
